# Copy to .env before local boot. OpenAI keys go only in ignored .env.local
# through infra/scripts/configure-openai-local.sh.
# Never commit real secrets.

APP_ENV=development
WEB_ORIGIN=http://localhost:5173
API_ORIGIN=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://nur_app:nur_app_pw@localhost:5432/nur
ALEMBIC_DATABASE_URL=postgresql+asyncpg://nur_admin:nur_admin_pw@localhost:5432/nur
REDIS_URL=redis://localhost:6379/0
NUR_POSTGRES_PORT=5432
NUR_REDIS_PORT=6379
NUR_SERVICE_MODE=local
NUR_DOCKER_SUFFIX=local
NUR_POSTGRES_CONTAINER_NAME=nur_postgres_local
NUR_REDIS_CONTAINER_NAME=nur_redis_local

SESSION_SECRET=dev_only_change_me
CSRF_SECRET=dev_only_change_me

# Account recovery: development captures reset mail in a mode-0600 ignored file.
# Production must use smtp, an HTTPS public origin, and real injected SMTP values.
PASSWORD_RESET_DELIVERY=local_capture
PASSWORD_RESET_LOCAL_CAPTURE_DIR=.nur-runtime/mail
# PASSWORD_RESET_PUBLIC_ORIGIN=https://app.example.com
# PASSWORD_RESET_FROM_EMAIL=security@example.com
# PASSWORD_RESET_SMTP_HOST=smtp.example.com
# PASSWORD_RESET_SMTP_PORT=587
# PASSWORD_RESET_SMTP_STARTTLS=true
# PASSWORD_RESET_SMTP_USERNAME=
# PASSWORD_RESET_SMTP_PASSWORD=

# AI is disabled by default. Set locally with the installer.
NUR_AI_PROVIDER=disabled
# OPENAI_API_KEY=
# NUR_OPENAI_MODEL=
NUR_OPENAI_REASONING_EFFORT=high
NUR_OPENAI_CRITICAL_REASONING_EFFORT=high
NUR_OPENAI_REQUEST_TIMEOUT_SECONDS=45
NUR_AI_PER_USER_DAILY_LIMIT=50
NUR_AI_DAILY_BUDGET_CENTS=500
NUR_AI_ALLOW_EXTERNAL_WEB_RESEARCH=false
NUR_AI_LOG_PROMPTS=false

# Billing is disabled by default. Production must never use the local test
# adapter. Live charges additionally require NUR_BILLING_LIVE_ENABLED=true.
NUR_BILLING_PROVIDER=disabled
NUR_BILLING_TEST_MODE=true
NUR_BILLING_LIVE_ENABLED=false
# NUR_BILLING_WEBHOOK_SECRET=
NUR_BILLING_CHECKOUT_RESERVATION_MINUTES=30
NUR_BILLING_PAST_DUE_GRACE_DAYS=3
# NUR_BILLING_TERMS_URL=https://example.com/terms
# NUR_BILLING_PRIVACY_URL=https://example.com/privacy
# NUR_BILLING_REFUND_POLICY_URL=https://example.com/refunds
# LEMON_SQUEEZY_API_KEY=
# LEMON_SQUEEZY_STORE_ID=
# LEMON_SQUEEZY_FOUNDING_ORBIT_VARIANT_ID=
# LEMON_SQUEEZY_PLUS_MONTHLY_VARIANT_ID=
# LEMON_SQUEEZY_PLUS_ANNUAL_VARIANT_ID=

# Hidden research UI and Omega v1 scheduler.
NUR_OMEGA_ENABLED=true
NUR_OMEGA_SCHEDULED_CONSOLIDATION=true
NUR_OMEGA_CONSOLIDATION_INTERVAL_HOURS=24
NUR_OMEGA_MAX_EXPERIENCES_PER_RUN=100
NUR_ENABLE_OMEGA_RESEARCH=true
VITE_NUR_ENABLE_OMEGA_RESEARCH=true
VITE_API_BASE_URL=

# Local demo seed credentials only.
NUR_DEMO_OWNER_EMAIL=owner@nur.app
NUR_DEMO_OWNER_PASSWORD=owner-demo-pass-123
NUR_DEMO_RECIPIENT_EMAIL=recipient@nur.app
NUR_DEMO_RECIPIENT_PASSWORD=recipient-demo-pass-123
